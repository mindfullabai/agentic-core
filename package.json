{
  "name": "@mindfullabai/agentic-core",
  "version": "0.2.0",
  "description": "Boilerplate generico per agenti always-on: runtime model-agnostic (Anthropic|Qwen), scheduler tick no-409, gate anti-spam, MemoryStore pluggable, Channel astratto, tool-registry tipizzato, loop conversazionale + identità, capability web-search/OCR/TTS/STT/whoop/hidrate/todoist.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindfullabai/agentic-core.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "CLAUDE.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "prepare": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.177",
    "dotenv": "^16.5.0",
    "luxon": "^3.6.1",
    "node-cron": "4.2.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@prisma/client": "^6.7.0",
    "grammy": "^1.44.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": { "optional": true },
    "grammy": { "optional": true }
  },
  "devDependencies": {
    "@prisma/client": "^6.7.0",
    "@types/luxon": "^3.6.2",
    "@types/node": "^22.15.17",
    "@types/node-cron": "^3.0.11",
    "grammy": "^1.44.0",
    "typescript": "^5.8.3"
  }
}
